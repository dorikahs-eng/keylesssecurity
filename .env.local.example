# Resend API key for sending invoice emails
# Get yours at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# The domain you've verified in Resend for sending FROM
# e.g. "keylesssecurity.com"
RESEND_FROM_DOMAIN=keylesssecurity.com

# Your deployed Vercel URL (used in email links)
# e.g. "https://keyless-security.vercel.app"
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --- Future Stripe integration ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxxx
